# ADOS Drone Agent Environment Variables
# Copy to .env and customize

# Server mode: cloud, self_hosted, hybrid
ADOS_SERVER_MODE=cloud

# Self-hosted server URL (required if mode is self_hosted or hybrid)
ADOS_SERVER_URL=
ADOS_MQTT_BROKER=
ADOS_API_KEY=

# Log level: debug, info, warning, error
ADOS_LOG_LEVEL=info

# OTA update channel: stable, beta, nightly
ADOS_UPDATE_CHANNEL=stable
