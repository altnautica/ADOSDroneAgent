# Top-level Config.in for the ADOS BR2_EXTERNAL tree.
#
# Buildroot sources this file via BR2_EXTERNAL=<path> and surfaces the
# per-package configs below in `make menuconfig` under the "External
# options" submenu.

source "$BR2_EXTERNAL_ADOS_PATH/package/ados-agent-lite/Config.in"
source "$BR2_EXTERNAL_ADOS_PATH/package/ados-rkmpi-wrapper/Config.in"
source "$BR2_EXTERNAL_ADOS_PATH/package/rtl8812eu/Config.in"
source "$BR2_EXTERNAL_ADOS_PATH/package/aic8800/Config.in"
