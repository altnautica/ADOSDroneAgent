#!/bin/sh
#
# S99ados-agent-lite — busybox sysv-rc init script for the lite agent.
# Used on Luckfox + other busybox-based boards. Systemd boards delete
# this file in their recipe::post_overlay hook and rely on
# /etc/systemd/system/ados-agent-lite.service instead.

DAEMON=/usr/local/bin/ados-agent-lite
PIDFILE=/var/run/ados-agent-lite.pid
LOGFILE=/var/log/ados-agent-lite.log
USER=root

start() {
    [ -x "${DAEMON}" ] || {
        echo "ados-agent-lite: daemon missing or not executable: ${DAEMON}" >&2
        exit 1
    }
    if [ -f "${PIDFILE}" ] && kill -0 "$(cat "${PIDFILE}")" 2>/dev/null; then
        echo "ados-agent-lite: already running"
        return 0
    fi
    mkdir -p "$(dirname "${LOGFILE}")"
    printf 'Starting ados-agent-lite: '
    start-stop-daemon -S -q -m -b -p "${PIDFILE}" -u "${USER}" \
        --exec "${DAEMON}" \
        -- >> "${LOGFILE}" 2>&1
    echo "OK"
}

stop() {
    printf 'Stopping ados-agent-lite: '
    start-stop-daemon -K -q -p "${PIDFILE}" --retry 10
    rm -f "${PIDFILE}"
    echo "OK"
}

case "$1" in
    start) start ;;
    stop)  stop ;;
    restart|reload) stop; sleep 1; start ;;
    status)
        if [ -f "${PIDFILE}" ] && kill -0 "$(cat "${PIDFILE}")" 2>/dev/null; then
            echo "ados-agent-lite is running (pid $(cat "${PIDFILE}"))"
        else
            echo "ados-agent-lite is not running"
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}" >&2
        exit 1
        ;;
esac
