  "gst_usb_mjpeg_rtsp_rk_mpp": [
    "gst-launch-1.0",
    "-e",
    "v4l2src",
    "device=/dev/video1",
    "!",
    "image/jpeg,width=1280,height=720,framerate=30/1",
    "!",
    "jpegdec",
    "!",
    "videoconvert",
    "!",
    "mpph264enc",
    "bps=4000000",
    "bps-max=6000000",
    "bps-min=2000000",
    "qp-min=5",
    "qp-max=51",
    "rc-mode=1",
    "gop=15",
    "header-mode=1",
    "!",
    "h264parse",
    "!",
    "rtspclientsink",
    "location=rtsp://127.0.0.1:8554/main",
    "protocols=tcp",
    "latency=0"
  ],
