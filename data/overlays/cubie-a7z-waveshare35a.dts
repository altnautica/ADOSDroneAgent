/*
 * Device-tree overlay: 480x320 SPI LCD (ILI9486 + ADS7846) on the
 * 40-pin expansion header of the Radxa Cubie A7Z (Allwinner A733,
 * sun55iw3p1).
 *
 * Wiring (40-pin header, physical pin -> SoC pad):
 *   19  PD12  SPI1 MOSI
 *   21  PD13  SPI1 MISO
 *   23  PD11  SPI1 CLK
 *   24  PD10  SPI1 CS0   (LCD chip-select, hardware-managed)
 *   26  PD14  GPIO       (touch CS1, driven via cs-gpios)
 *   18  PJ25  GPIO out   (LCD data/command select)
 *   22  PL5   GPIO out   (LCD reset, on the AO/RTC pinctrl block)
 *   11  PB1   GPIO in    (touch pendown IRQ)
 *
 * Touch is enabled. The XPT2046/ADS7846 PENIRQ line is open-drain and
 * pulls low while the pen is down, so the IRQ trigger is FALLING-edge
 * and pendown-gpio is ACTIVE_LOW.
 *
 * Bank-index assumption: Allwinner ``pio`` numbers banks A..J as 0..9
 * and the AO ``r_pio`` numbers PL=0, PM=1. Verify against the in-tree
 * sun55iw3p1 DTS on the first bench cycle and adjust if the running
 * kernel uses a different convention before tagging this overlay
 * stable.
 */

/dts-v1/;
/plugin/;

/*
 * GPIO + IRQ flag values are inlined as integer literals (instead of
 * dt-bindings #include macros) so this overlay compiles via plain
 * ``dtc -I dts -O dtb`` without a cpp pre-process pass. Values match
 * the kernel's stable ABI: GPIO_ACTIVE_HIGH=0, GPIO_ACTIVE_LOW=1,
 * IRQ_TYPE_EDGE_FALLING=2.
 */

/ {
    compatible = "allwinner,sun55iw3p1";

    fragment@0 {
        target = <&pio>;
        __overlay__ {
            spi1_pins: spi1-pins {
                pins = "PD10", "PD11", "PD12", "PD13";
                function = "spi1";
            };

            ados_lcd_dc_pin: ados-lcd-dc-pin {
                pins = "PJ25";
                function = "gpio_out";
            };

            ados_touch_cs_pin: ados-touch-cs-pin {
                pins = "PD14";
                function = "gpio_out";
            };

            ados_touch_irq_pin: ados-touch-irq-pin {
                pins = "PB1";
                function = "gpio_in";
            };
        };
    };

    fragment@1 {
        target = <&r_pio>;
        __overlay__ {
            ados_lcd_reset_pin: ados-lcd-reset-pin {
                pins = "PL5";
                function = "gpio_out";
            };
        };
    };

    fragment@2 {
        target = <&spi1>;
        __overlay__ {
            status = "okay";
            #address-cells = <1>;
            #size-cells = <0>;
            num-cs = <2>;

            pinctrl-names = "default";
            pinctrl-0 = <&spi1_pins>,
                        <&ados_lcd_dc_pin>,
                        <&ados_lcd_reset_pin>,
                        <&ados_touch_cs_pin>,
                        <&ados_touch_irq_pin>;

            cs-gpios = <0>,                                 /* CS0: hardware-managed for LCD on PD10 */
                       <&pio 3 14 1>;                       /* CS1: PD14, GPIO chip-select for touch (active-low) */

            ili9486: ili9486@0 {
                compatible = "ilitek,ili9486";
                reg = <0>;
                spi-max-frequency = <16000000>;
                txbuflen = <32768>;
                rotate = <90>;
                bgr = <0>;
                fps = <30>;
                buswidth = <8>;
                regwidth = <16>;
                debug = <0>;
                /* PJ25 — header pin 18 — &pio bank 9, active high */
                dc-gpios = <&pio 9 25 0>;
                /* PL5 — header pin 22 — &r_pio bank 0, active low */
                reset-gpios = <&r_pio 0 5 1>;
            };

            ads7846: ads7846@1 {
                compatible = "ti,ads7846";
                reg = <1>;
                status = "okay";
                spi-max-frequency = <2000000>;
                /* PB1 — header pin 11 — &pio bank 1, falling-edge IRQ */
                interrupt-parent = <&pio>;
                interrupts = <1 1 2>;
                pendown-gpio = <&pio 1 1 1>;
                ti,x-plate-ohms = /bits/ 16 <60>;
                ti,pressure-max = /bits/ 16 <255>;
                ti,swap-xy = <0>;
                touchscreen-max-pressure = <255>;
            };
        };
    };
};
