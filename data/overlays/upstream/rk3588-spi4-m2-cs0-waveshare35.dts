// SPDX-License-Identifier: GPL-2.0-or-later
/*
 * Activate the 480x320 ILI9486 SPI LCD on the SPI4 controller's M2 pad
 * mux. On boards that route SPI4_M2 onto the 40-pin expansion header at
 * the same physical pin positions as the Raspberry Pi puts SPI0 (Rock 5A
 * / Rock 5C / Rock 5D), this lets a Pi-style 3.5" LCD HAT plug in
 * directly. Touch is enabled.
 *
 * Polarity note (Rockchip convention): even though the XPT2046/ADS7846
 * PENIRQ line is electrically open-drain pull-low, every working Rockchip
 * Linux config (Radxa Rock 3B docs and the rk3568 spi3 waveshare35
 * overlay both ship pendown-gpio = GPIO_ACTIVE_HIGH paired with
 * IRQ_TYPE_EDGE_FALLING) treats the gpio flag as ACTIVE_HIGH on this
 * platform. The IRQ trigger stays EDGE_FALLING because the IRQ
 * controller still sees the physical hi -> lo transition produced by
 * pen contact; only the pendown-gpio flag gets the platform-convention
 * value. Older versions of this overlay shipped ACTIVE_LOW, which never
 * fired (verified on Rock 5C Lite via /proc/interrupts ads7846 = 0
 * across all CPUs).
 *
 * Pinmux note: the PENIRQ pin needs both the GPIO function AND a
 * pull-up bias to register clean falling edges. Without the explicit
 * pinctrl-0 block below, /sys/kernel/debug/pinctrl reports
 * "pin 139 (gpio4-11): (MUX UNCLAIMED)" and the line floats. Touch
 * stays dead with ads7846 IRQ count = 0 across boots until the pin
 * is muxed back to GPIO with pcfg_pull_up.
 */

#define DISPLAY_SPI spi4
#include "waveshare35-lcd.dtsi"

/ {
    metadata {
        title = "Enable Waveshare 3.5inch RPi LCD on SPI4";
        compatible = "radxa,rock-5a", "radxa,rock-5c", "radxa,rock-5d";
        category = "misc";
        exclusive = "GPIO1_A2", "GPIO1_A0", "GPIO1_A1", "GPIO1_A3", "GPIO1_B0", "GPIO1_B5", "GPIO4_B3";
        description = "Enable the 480x320 ILI9486 SPI LCD on SPI4 with ADS7846 resistive touch.";
    };
};


&DISPLAY_SPI {
    pinctrl-0 = <&spi4m2_pins>;
    num-cs = <2>;
    cs-gpios = <&gpio1 RK_PA3 GPIO_ACTIVE_LOW
                &gpio1 RK_PA4 GPIO_ACTIVE_LOW>;
};

&ili9486 {
    reset-gpios = <&gpio1 RK_PB5 GPIO_ACTIVE_LOW>;
    dc-gpios = <&gpio1 RK_PB0 GPIO_ACTIVE_HIGH>;
};

&pinctrl {
    ados-waveshare35 {
        ads7846_irq: ads7846-irq {
            rockchip,pins = <4 RK_PB3 RK_FUNC_GPIO &pcfg_pull_up>;
        };
    };
};

&ads7846 {
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&ads7846_irq>;
    interrupt-parent = <&gpio4>;
    interrupts = <RK_PB3 IRQ_TYPE_EDGE_FALLING>;
    pendown-gpio = <&gpio4 RK_PB3 GPIO_ACTIVE_HIGH>;
    touchscreen-max-pressure = <255>;
};
