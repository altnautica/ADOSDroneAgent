[Unit]
Description=ADOS REST API
After=ados-mavlink.service
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
ExecStart=/opt/ados/venv/bin/python -m ados.services.api
Restart=always
RestartSec=2
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

NoNewPrivileges=yes
ProtectSystem=strict
# Plugin lifecycle runs inside this service: POST /api/plugins/install drives
# the supervisor, which writes per-plugin unit files and the shared slice
# under /etc/systemd/system and removes them on uninstall, so /etc must be
# writable. Runtime config writes (config.yaml, peripherals, display.conf)
# land under /etc/ados. /var/lib/ados holds plugin state. /tmp is writable so
# the plugin upload is staged via a temp file before the supervisor unpacks
# it. The radio bind keygen no longer runs here (it moved to the supervisor).
ReadWritePaths=/var/ados /run/ados /etc /tmp /var/lib/ados

MemoryMax=128M
CPUQuota=25%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-api

[Install]
WantedBy=ados-supervisor.service
