[Unit]
Description=ADOS Physical Buttons (ground-station profile)
PartOf=ados-supervisor.service
ConditionPathExists=/dev/gpiochip0
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
User=root
SupplementaryGroups=gpio
ExecStart=/opt/ados/venv/bin/python -m ados.services.ui.button_service
Restart=on-failure
RestartSec=5
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

MemoryMax=48M

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-buttons

[Install]
WantedBy=ados-supervisor.service
