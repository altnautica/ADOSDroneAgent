[Unit]
Description=ADOS mDNS Discovery
After=network-online.target
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5

[Service]
Type=simple
ExecStart=/opt/ados/venv/bin/python -m ados.services.discovery
Restart=on-failure
RestartSec=10
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/ados /run/ados /etc/ados

MemoryMax=20M
CPUQuota=5%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-discovery

[Install]
WantedBy=ados-supervisor.service
