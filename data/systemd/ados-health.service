[Unit]
Description=ADOS Health Monitor
After=network-online.target
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
ExecStart=/opt/ados/venv/bin/python -m ados.services.health
Restart=always
RestartSec=1
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/ados /run/ados /etc/ados

MemoryMax=20M
CPUQuota=5%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-health

[Install]
WantedBy=ados-supervisor.service
