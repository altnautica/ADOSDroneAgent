[Unit]
Description=ADOS Input Manager (ground-station profile)
After=ados-supervisor.service
PartOf=ados-supervisor.service

[Service]
Type=simple
User=root
SupplementaryGroups=input plugdev bluetooth
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env
ExecStart=/opt/ados/venv/bin/python -m ados.services.ground_station.input_manager
Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-input

[Install]
WantedBy=multi-user.target
