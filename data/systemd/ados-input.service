[Unit]
Description=ADOS Input Manager (ground-station profile)
PartOf=ados-supervisor.service
# Skip cleanly when the binary was not fetched for this profile rather than
# crash-looping; the installer health gate is the loud failure for a binary
# that should be present on a ground station.
ConditionPathExists=/opt/ados/bin/ados-input
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
User=root
SupplementaryGroups=input plugdev bluetooth
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env
# Native-only: the packaged Python input manager was deleted, so the daemon runs
# its binary directly.
ExecStart=/opt/ados/bin/ados-input
Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-input

[Install]
WantedBy=multi-user.target
