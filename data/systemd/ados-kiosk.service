[Unit]
Description=ADOS HDMI Kiosk (ground-station profile)
After=graphical.target ados-mediamtx-gs.service
PartOf=ados-supervisor.service
# No ConditionPathExists on the DRM node: the KMS display device can be created
# a few seconds after this unit starts at boot (a boot race that a one-shot
# condition loses, skipping the kiosk forever). The service instead WAITS for a
# DRM display to appear and exits cleanly if none does (a headless box).
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
User=root
# No DISPLAY is set here: the appliance (cage) path uses cage's own DRM backend
# and the service strips DISPLAY/WAYLAND_DISPLAY so cage never tries to nest
# under an absent X server; the windowed (live-desktop) path derives DISPLAY /
# WAYLAND_DISPLAY from the detected login session instead.
Environment=ADOS_CONFIG=/etc/ados/config.yaml
Environment=XDG_RUNTIME_DIR=/run/user/0
EnvironmentFile=-/etc/ados/env
ExecStart=/opt/ados/venv/bin/python -m ados.services.kiosk.kiosk_service
Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-kiosk

[Install]
WantedBy=multi-user.target
