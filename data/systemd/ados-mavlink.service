[Unit]
Description=ADOS MAVLink Proxy
After=network-online.target
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
# Prefer the prebuilt native router when present, fall back to the packaged
# Python service otherwise (the prebuilt fetch is best-effort). `exec` hands the
# process identity to the chosen binary so the cgroup + restart track it.
ExecStart=/bin/sh -c 'if [ -x /opt/ados/bin/ados-mavlink-router ]; then exec /opt/ados/bin/ados-mavlink-router; else exec /opt/ados/venv/bin/python -m ados.services.mavlink; fi'
Restart=always
RestartSec=1
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

# MAVLink needs serial port access
SupplementaryGroups=dialout
NoNewPrivileges=yes
ProtectSystem=strict
# /var/lib/ados holds the persistent parameter cache (params.json).
ReadWritePaths=/var/ados /var/lib/ados /run/ados /dev /etc/ados

# Resource limits
MemoryMax=50M
CPUQuota=25%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-mavlink

[Install]
WantedBy=ados-supervisor.service
