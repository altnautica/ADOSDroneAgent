[Unit]
Description=ADOS MAVLink Proxy
After=network-online.target
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
# The native router owns the FC link, the direct-GCS proxies, and the state
# IPC publish. It is the only MAVLink command-and-control path; there is no
# packaged fallback. If the binary is absent the unit fails visibly
# (Restart=on-failure). The installer Hard-gates the router's fetch and
# re-checks its on-disk presence in the health gate, so a missing binary fails
# the install rather than reporting OK while this unit crash-loops with no FC
# link.
ExecStart=/opt/ados/bin/ados-mavlink-router
Restart=on-failure
RestartSec=1
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

# MAVLink needs serial port access
SupplementaryGroups=dialout
NoNewPrivileges=yes
ProtectSystem=strict
# /var/lib/ados holds the persistent parameter cache (params.json).
ReadWritePaths=/var/ados /var/lib/ados /run/ados /dev /etc/ados

# Resource limits
MemoryMax=50M
CPUQuota=25%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-mavlink

[Install]
WantedBy=ados-supervisor.service
