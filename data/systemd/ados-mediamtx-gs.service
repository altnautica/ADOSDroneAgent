[Unit]
Description=ADOS mediamtx Manager (ground-station profile)
After=ados-wfb-rx.service
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
ExecStart=/opt/ados/venv/bin/python -m ados.services.ground_station.mediamtx_manager
Restart=on-failure
RestartSec=5
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/ados /run/ados /etc/ados /tmp

MemoryMax=256M

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-mediamtx-gs

[Install]
WantedBy=ados-supervisor.service
