[Unit]
Description=ADOS Captive Portal DNS + HTTP responder (first-boot only)
After=ados-supervisor.service ados-hostapd.service
PartOf=ados-supervisor.service

[Service]
Type=simple
User=root
# Negated path check: only start while setup is incomplete. Once the
# sentinel file exists the unit exits 0 and does not come back.
ExecStartPre=/bin/bash -c '[ ! -f /var/lib/ados/setup-complete ] || exit 1'
ExecStart=/opt/ados/venv/bin/python -m ados.services.setup_webapp.captive_dns
Restart=no
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=no

MemoryMax=48M

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-setup-captive

[Install]
WantedBy=ados-supervisor.service
