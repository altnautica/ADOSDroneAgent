[Unit]
Description=ADOS Drone Agent Supervisor
# Deliberately NOT After=/Wants=network-online.target.
# The radio link (WFB-ng on RTL8812EU monitor mode) and the entire
# video pipeline (camera -> encoder -> tee -> wfb_tx | wfb_rx ->
# ffmpeg sidecar -> mediamtx -> LCD) operate locally. They do not
# need DHCP, DNS, or a default route. Only the cloud-relay heartbeat
# child needs internet, and it retries indefinitely on its own.
# Gating the supervisor on network-online previously left the LCD
# blank for hours when the home Wi-Fi failed to associate at boot.
# Per Rule 26: "the install must be 100% AUTOMATIC" — an operator
# on a deserted island with both rigs powered must see video.
After=local-fs.target
StartLimitInterval=60s
StartLimitBurst=5

[Service]
Type=notify
ExecStart=/opt/ados/venv/bin/ados-supervisor
Restart=always
RestartSec=1
WatchdogSec=30
TimeoutStartSec=60
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

# Security
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/ados /etc/ados /run/ados

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-supervisor

[Install]
WantedBy=multi-user.target
