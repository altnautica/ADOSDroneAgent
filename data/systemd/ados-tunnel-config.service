[Unit]
Description=ADOS Config-over-Radio Channel
PartOf=ados-supervisor.service
StartLimitInterval=60s
StartLimitBurst=5
# Opt-in: the channel runs only on a node whose config enables it. The marker
# mirrors `radio.tunnel.enabled` and is reconciled by the installer and the
# config persist path (never hand-managed), so a node that never opts in skips
# this unit cleanly at boot.
ConditionPathExists=/etc/ados/tunnel-enabled

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are observable.
Slice=ados.slice
Type=simple
# The native binary is fetched best-effort (the channel is opt-in); until it
# lands the guard execs /bin/true so the unit is a clean no-op rather than a
# restart loop.
ExecStart=/bin/sh -c 'if [ -x /opt/ados/bin/ados-tunnel-config ]; then exec /opt/ados/bin/ados-tunnel-config; else exec /bin/true; fi'
# In-process config reload: the service re-reads /etc/ados/config.yaml on
# SIGHUP and re-runs its gates, so a config change (enable, open the write
# gate) applies without dropping the unit and without an operator systemctl.
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
Environment=ADOS_CONFIG=/etc/ados/config.yaml
Environment=RUST_LOG=info
EnvironmentFile=-/etc/ados/env

# The channel binds loopback UDP ports and calls the local config surface on
# 127.0.0.1:8080 — no raw-socket / net-admin capabilities (it never touches the
# WFB sockets or the FC lane; a separate radio bridge carries its frames onto
# -p1).
NoNewPrivileges=yes
ProtectSystem=strict
PrivateTmp=yes
ReadWritePaths=/run/ados

# Lightweight native service; cap it in the radio-service range so a runaway
# can never starve the box.
MemoryMax=64M
CPUQuota=20%

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-tunnel-config

[Install]
# Enable-linked cross-profile by the installer; systemd pulls it up with the
# supervisor and the ConditionPathExists gate keeps it skipped until the config
# opts the channel in.
WantedBy=ados-supervisor.service
