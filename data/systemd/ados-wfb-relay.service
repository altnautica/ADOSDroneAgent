[Unit]
Description=ADOS WFB-ng relay (mesh relay role)
After=ados-batman.service
Wants=ados-batman.service
PartOf=ados-supervisor.service
# Only runs when the role sentinel reads `relay`. role_manager owns this file.
ConditionPathExists=/etc/ados/mesh/role
StartLimitInterval=60s
StartLimitBurst=5

[Service]
# Join the shared accounting slice so MemoryCurrent/CPUUsage are
# observable per unit (the slice sets MemoryAccounting=yes).
Slice=ados.slice
Type=simple
User=root
# Flag-gated cutover, mirroring ados-wfb-rx.service: the native relay loop runs
# only when BOTH the operator enabled the flag file AND the binary is present;
# otherwise the packaged Python relay is the default, so a routine upgrade never
# changes behavior. The native binary takes the role on its `--role` argument.
# To turn the native relay on for a bench:
#   touch /etc/ados/groundlink-rust-enabled && systemctl restart ados-wfb-relay
# `exec` replaces the shell image so the ambient caps below carry unchanged.
ExecStart=/bin/sh -c 'if [ -e /etc/ados/groundlink-rust-enabled ] && [ -x /opt/ados/bin/ados-groundlink ]; then exec /opt/ados/bin/ados-groundlink --role relay; else exec /opt/ados/venv/bin/python -m ados.services.ground_station.wfb_relay; fi'
Restart=on-failure
RestartSec=5
Environment=ADOS_CONFIG=/etc/ados/config.yaml
EnvironmentFile=-/etc/ados/env

# Relay shells out to wfb_rx -f which needs raw socket + monitor mode.
AmbientCapabilities=CAP_NET_RAW CAP_NET_ADMIN
NoNewPrivileges=no
ProtectSystem=strict
ReadWritePaths=/var/ados /run/ados /dev /etc/ados

MemoryMax=64M

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ados-wfb-relay

[Install]
WantedBy=ados-supervisor.service
