<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ados_mavlink_bridge</name>
  <version>0.1.0</version>
  <description>
    Custom MAVLink bridge for ADOS Drone Agent.
    Reads binary MAVLink frames from /run/ados/mavlink.sock and publishes
    mavros-compatible ROS 2 topics. Subscribes to velocity setpoints and
    encodes them back to MAVLink for the flight controller.
  </description>
  <maintainer email="team@altnautica.com">Altnautica</maintainer>
  <license>GPL-3.0-only</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <exec_depend>rclpy</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>geometry_msgs</exec_depend>
  <exec_depend>nav_msgs</exec_depend>
  <exec_depend>diagnostic_msgs</exec_depend>
  <exec_depend>tf2_ros</exec_depend>
  <exec_depend>std_msgs</exec_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
