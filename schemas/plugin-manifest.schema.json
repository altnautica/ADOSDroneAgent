          "type": "boolean"
        },
        "contributes": {
          "$ref": "#/$defs/AgentContributes"
        },
        "entrypoint": {
          "title": "Entrypoint",
          "type": "string"
        },
        "isolation": {
          "default": "subprocess",
          "enum": [
            "subprocess",
            "inprocess"
